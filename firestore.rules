rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /artifacts/{appId}/public/data/water_filter_tasks/{taskId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.clientName is string
        && request.resource.data.clientName.size() > 0
        && request.resource.data.status is string;
      allow delete: if request.auth != null;
    }

    match /artifacts/{appId}/public/data/clients/{clientId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.identification is string
        && request.resource.data.identification.size() > 0;
      allow delete: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
	
	match /artifacts/{appId}/public/data/tipos_visita/{id} {
		allow read: if request.auth != null;
		allow write: if request.auth != null;
	}
	
	match /artifacts/{appId}/public/data/tecnicos/{id} {
		allow read: if request.auth != null;
		allow write: if request.auth != null;
	}
  }
}